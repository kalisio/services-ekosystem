{
  "name": "@kalisio/katalog",
  "description": "Catalog service for KDK-based applications",
  "version": "0.0.0",
  "type": "module",
  "main": "src/",
  "engines": {
    "node": ">= 20.19.0"
  },
  "feathers": {
    "language": "js",
    "packager": "pnpm",
    "database": "mongodb",
    "framework": "express",
    "transports": [
      "rest"
    ],
    "schema": false
  },
  "directories": {
    "lib": "src",
    "test": "test"
  },
  "exports": {
    ".": {
      "development": "./src/index.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "lib/**/*.d.ts",
    "lib/**/*.shared.js"
  ],
  "standard": {
    "ignore": [
      "dist/**"
    ]
  },
  "scripts": {
    "build": "vite build",
    "dev": "node --conditions=development --watch src/main.js",
    "lint": "standard --fix",
    "link:kdk-map-api": "rm -f node_modules/@kalisio/kdk-map-api && ln -s $(realpath ../../../kdk-ekosystem/packages/kdk-map-api) node_modules/@kalisio/kdk-map-api",
    "test": "vitest run --coverage"
  },
  "keywords": [
    "kalisio"
  ],
  "author": {
    "name": "KALISIO <contact@kalisio.com>",
    "url": "https://github.com/kalisio"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/kalisio/services-ekosystem.git",
    "directory": "packages/katalog"
  },
  "bugs": {
    "url": "https://github.com/kalisio/services-ekosystem/issues"
  },
  "homepage": "https://github.com/kalisio/services-ekosystem/tree/main/packages/katalog",
  "dependencies": {
    "@feathersjs/authentication": "catalog:",
    "@feathersjs/configuration": "catalog:",
    "@feathersjs/errors": "catalog:",
    "@feathersjs/express": "catalog:",
    "@feathersjs/feathers": "catalog:",
    "@feathersjs/socketio": "catalog:",
    "@kalisio/feathers-distributed": "catalog:",
    "@kalisio/kdk-core-api": "link:../../../kdk-ekosystem/packages/kdk-core-api",
    "@kalisio/kdk-map-api": "link:../../../kdk-ekosystem/packages/kdk-map-api",
    "glob": "catalog:",
    "winston": "catalog:"
  },
  "devDependencies": {}
}