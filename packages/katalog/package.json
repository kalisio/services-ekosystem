{
  "name": "@kalisio/katalog",
  "description": "Catalog service for KDK-based applications",
  "version": "0.0.0",
  "type": "module",
  "main": "src/",
  "engines": {
    "node": ">= 20.19.0"
  },
  "feathers": {
    "language": "js",
    "packager": "pnpm",
    "database": "mongodb",
    "framework": "express",
    "transports": [
      "rest"
    ],
    "schema": false
  },
  "directories": {
    "lib": "src",
    "test": "test"
  },
  "exports": {
    ".": {
      "development": "./src/index.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "lib/client.js",
    "lib/**/*.d.ts",
    "lib/**/*.shared.js"
  ],
  "standard": {
    "ignore": [
      "dist/**"
    ]
  },
  "scripts": {
    "build": "vite build",
    "lint": "standard --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "start": "node src/main.js",
    "dev": "node --watch src/",
    "prettier": "npx prettier \"**/*.js\" --write"
  },
  "keywords": [
    "kalisio"
  ],
  "author": {
    "name": "KALISIO <contact@kalisio.com>",
    "url": "https://github.com/kalisio"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/kalisio/services-ekosystem.git",
    "directory": "packages/katalog"
  },
  "bugs": {
    "url": "https://github.com/kalisio/services-ekosystem/issues"
  },
  "homepage": "https://github.com/kalisio/services-ekosystem/tree/main/packages/katalog",
  "dependencies": {
    "@feathersjs/adapter-commons": "catalog:",
    "@feathersjs/authentication": "catalog:",
    "@feathersjs/authentication-client": "catalog:",
    "@feathersjs/configuration": "catalog:",
    "@feathersjs/errors": "catalog:",
    "@feathersjs/express": "catalog:",
    "@feathersjs/feathers": "catalog:",
    "@feathersjs/mongodb": "catalog:",
    "@feathersjs/socketio": "catalog:",
    "@kalisio/feathers-distributed": "catalog:",
    "mongodb": "catalog:",
    "winston": "catalog:"
  },
  "devDependencies": {

  }
}