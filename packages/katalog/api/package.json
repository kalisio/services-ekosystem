{
  "name": "api",
  "description": "Katalog api",
  "version": "0.0.0",
  "homepage": "",
  "private": true,
  "keywords": [
    "feathers"
  ],
  "engines": {
    "node": ">= 20.19.0"
  },
  "feathers": {
    "language": "js",
    "packager": "pnpm",
    "database": "mongodb",
    "framework": "express",
    "transports": [
      "rest"
    ],
    "schema": false
  },
  "directories": {
    "lib": "src",
    "test": "test"
  },
  "files": [
    "lib/client.js",
    "lib/**/*.d.ts",
    "lib/**/*.shared.js"
  ],
  "main": "src/",
  "type": "module",
  "scripts": {
    "start": "node src/",
    "dev": "node --watch src/",
    "test": "vitest run",
    "prettier": "npx prettier \"**/*.js\" --write",
    "bundle:client": "npm pack --pack-destination ./public"
  },
  "dependencies": {
    "@feathersjs/adapter-commons": "catalog:",
    "@feathersjs/authentication": "catalog:",
    "@feathersjs/authentication-client": "catalog:",
    "@feathersjs/configuration": "catalog:",
    "@feathersjs/errors": "catalog:",
    "@feathersjs/express": "catalog:",
    "@feathersjs/feathers": "catalog:",
    "@feathersjs/mongodb": "catalog:",
    "@feathersjs/socketio": "catalog:",
    "@kalisio/feathers-distributed": "catalog:",
    "mongodb": "catalog:",
    "winston": "catalog:"
  },
  "devDependencies": {
    "@feathersjs/rest-client": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "cross-env": "catalog:",
    "prettier": "catalog:",
    "vitest": "catalog:"
  }
}