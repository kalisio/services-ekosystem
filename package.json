{
  "name": "service-ekosystem",
  "description": "A suite of cloud services for geospatial platforms",
  "type": "module",
  "packageManager": "pnpm@10.1.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:service-geokoder": "pnpm --filter @kalisio/service-geokoder build",
    "build:service-kapture": "pnpm --filter @kalisio/service-kapture build",
    "build:service-katalog": "pnpm --filter @kalisio/service-katalog build",
    "changeset": "changeset",
    "changeset:release": "pnpm build && changeset publish",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "docs:build": "pnpm --filter docs run build",
    "docs:dev": "pnpm --filter docs run dev",
    "inspect": "pnpm knip",
    "lint": "pnpm -r lint",
    "lint:service-geokoder": "pnpm --filter @kalisio/service-geokoder lint",
    "lint:service-kapture": "pnpm --filter @kalisio/service-kapture lint",
    "lint:service-katalog": "pnpm --filter @kalisio/service-katalog lint",
    "posttest": "pnpm lcov-result-merger --prepend-source-files 'packages/*/coverage/lcov.info' coverage/lcov.info",
    "prepare": "husky",
    "pretest": "mkdir -p coverage",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "test:service-geokoder": "pnpm --filter @kalisio/service-geokoder test",
    "test:service-kapture": "pnpm --filter @kalisio/service-kapture test",
    "test:service-katalog": "pnpm --filter @kalisio/service-katalog test"
  },
  "keywords": [
    "kalisio"
  ],
  "author": {
    "name": "KALISIO <contact@kalisio.com>",
    "url": "https://github.com/kalisio"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/kalisio/service-ekosystem.git"
  },
  "bugs": {
    "url": "https://github.com/kalisio/service-ekosystem/issues"
  },
  "homepage": "git://github.com/kalisio/service-ekosystem#readme",
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "husky": "catalog:",
    "is-docker": "catalog:",
    "knip": "catalog:",
    "lcov-result-merger": "catalog:",
    "lint-staged": "catalog:",
    "standard": "catalog:",
    "vite": "catalog:",
    "vite-bundle-visualizer": "catalog:",
    "vitest": "catalog:"
  },
  "metaCatalog": {
    "version": "0.10.0",
    "syncedAt": "2026-06-10T15:33:07.911Z"
  },
  "pnpm": {
